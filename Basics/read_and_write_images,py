import cv2 as cv
import os
import matplotlib.pyplot as plt
import numpy as np

def readImage():

    root = os.getcwd()
    imgPath = os.path.join(root, 'demo_Images', 'REMultiV1.png')
    img = cv.imread(imgPath)
    debug = 1
    cv.imshow("img", img)
    cv.waitKey(0)

def writeImage():
    root = os.getcwd()
    imgPath = os.path.join(root, 'demo_Images', 'REMultiV1.png')
    img = cv.imread(imgPath)

    outputPath = os.path.join(root, 'demo_Images', 'OutputImage.png')
    cv.imwrite(outputPath, img)





